           <string>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd"&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name="qrichtext" content="1" /&gt;&lt;meta charset="utf-8" /&gt;&lt;style type="text/css"&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=" font-family:'Segoe UI'; font-size:10pt; font-weight:400; font-style:normal;"&gt;
&lt;h2 style=" margin:0 0 8px 0;"&gt;&lt;span style=" font-size:20pt; font-weight:700; color:#93C5FD;"&gt;SecureData Suite&lt;/span&gt;&lt;/h2&gt;
&lt;p style=" margin:0 0 10px 0;"&gt;Educational toolkit for cryptography and steganography experiments.&lt;/p&gt;
&lt;ul style="margin-top: 0px; margin-bottom: 0px;"&gt;
&lt;li&gt;8 cryptographic algorithms&lt;/li&gt;
&lt;li&gt;LSB steganography for PNG/BMP&lt;/li&gt;
&lt;li&gt;File encryption with automatic cache&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=" margin:10px 0 0 0; color:#94A3B8;"&gt;Hint: there are two hidden utilities below.&lt;/p&gt;
&lt;/body&gt;&lt;/html&gt;</string>
